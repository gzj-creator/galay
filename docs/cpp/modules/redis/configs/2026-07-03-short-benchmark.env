# Galay Redis benchmark rerun parameters for the 2026-07-03 blocked probe.
GALAY_REDIS_HOST=127.0.0.1
GALAY_REDIS_PORT=6379
GALAY_BUILD_DIR=build-release
GALAY_BUILD_TYPE=Release
GALAY_BUILD_BENCHMARKS=ON
GALAY_BUILD_REDIS=ON
GALAY_BUILD_SSL=ON
BUILD_TESTING=OFF

REDIS_CLIENTS=50
REDIS_REQUESTS=100000
REDIS_PIPELINE_DEPTHS="1 10 50 100"
REDIS_DATA_SIZE=64

GALAY_SHORT_CLIENTS=10
GALAY_SHORT_OPERATIONS=10000
GALAY_PIPELINE_OPERATIONS=50000
GALAY_PIPELINE_DEPTH=100
GALAY_TIMEOUT_MS=-1
GALAY_BUFFER_SIZE=32768
GALAY_POOL_WORKERS=20
GALAY_POOL_OPERATIONS=300
GALAY_POOL_MIN_CONNECTIONS=4
GALAY_POOL_MAX_CONNECTIONS=20

PROBE_STATUS=blocked
PROBE_RELEASE_DATA_VALID=false
PROBE_REASON="Current build is Debug with GALAY_BUILD_BENCHMARKS=OFF; Redis service at 127.0.0.1:6379 refused connections."
